# Movana Backend Environment Configuration
PORT=8000
HOST=0.0.0.0
ENV=development

# Google Gemini API Key (Required for Chat & RAG)
GEMINI_API_KEY=your_gemini_api_key_here

# Local Vector Database Storage Directory
CHROMADB_DIR=./chroma_db

# CPU-Optimized Whisper Model ("tiny", "base", "small")
# "tiny" is recommended for minimal memory (ideal for 512MB RAM servers or quick local runs)
WHISPER_MODEL=tiny
